# OpenRouter API Configuration
# Get your API key at https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM Model to use via OpenRouter
# Free options: meta-llama/llama-3.1-8b-instruct:free, google/gemma-2-9b-it:free
# Paid options: anthropic/claude-3.5-sonnet, openai/gpt-4o, openai/gpt-4.1
DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# Directory containing PDF files to ingest
PDF_DIR=./pdfs

# Directory for ChromaDB persistent storage
CHROMA_PERSIST_DIR=./chroma_db

# Table extraction and OCR options
# Disable if you want fastest ingestion with text-only parsing
TABLE_EXTRACTION_ENABLED=true
OCR_ENABLED=true

# OCR tuning (applies when OCR is enabled)
OCR_MIN_TEXT_CHARS=250
OCR_MIN_IMAGES=1
OCR_LANG=eng
OCR_MIN_IMAGE_COVERAGE=0.6
OCR_MAX_DRAWINGS=100
